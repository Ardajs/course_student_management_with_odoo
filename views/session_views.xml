<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_session_tree" model="ir.ui.view">
        <field name="name">session.student_management.tree</field>
        <field name="model">session.student_management</field>
        <field name="arch" type="xml">
            <tree string="Sessions">
                <field name="name"/>
                <field name="course_id"/>
                <field name="student_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
            </tree>
        </field>
    </record>

    <record id="view_session_form" model="ir.ui.view">
        <field name="name">session.student_management.form</field>
        <field name="model">session.student_management</field>
        <field name="arch" type="xml">
            <form string="Session">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="course_id"/>
                        <field name="student_id"/>
                    </group>

                    <group>
                        <field name="start_date"/>
                        <field name="end_date"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_session_search" model="ir.ui.view">
        <field name="name">session.student_management.search</field>
        <field name="model">session.student_management</field>
        <field name="arch" type="xml">
            <search string="Sessions">
                <field name="name"/>
                <field name="course_id"/>
                <field name="student_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
            </search>
        </field>
    </record>

</odoo>