<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_course_tree" model="ir.ui.view">
        <field name="name">course.student_management.tree</field>
        <field name="model">course.student_management</field>
        <field name="arch" type="xml">
            <tree string="Courses">
                <field name="name"/>
                <field name="session_count"/>
            </tree>
        </field>
    </record>


    <record id="view_course_form" model="ir.ui.view">
        <field name="name">course.student_management.form</field>
        <field name="model">course.student_management</field>
        <field name="arch" type="xml">
            <form string="Course">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="session_count" readonly="1"/>
                    </group>

                    <notebook>
                        <page string="Sessions">
                            <field name="session_ids">
                                <tree editable="bottom">
                                    <field name="name"/>
                                    <field name="start_date"/>
                                    <field name="end_date"/>
                                    <field name="student_id"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_course_search" model="ir.ui.view">
        <field name="name">course.student_management.search</field>
        <field name="model">course.student_management</field>
        <field name="arch" type="xml">
            <search string="Courses">
                <field name="name"/>
                <field name="description"/>
            </search>
        </field>
    </record>





</odoo>